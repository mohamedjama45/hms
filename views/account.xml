<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <data>

        <record id="accountka_form" model="ir.ui.view">
            <field name="name">accountka.form</field>
            <field name="model">account.payment</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="suitable_journal_ids" invisible="1"/>
                            <field name="journal_id"/>
                            <field name="amount"/>
                            <field name="discount_type"/>
                            <field name="fixed_discount" invisible="discount_type != 'fixed'"/>
                            <field name="fixed_percentage"  invisible="discount_type != 'percentage'"/>
                       </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>

</odoo>