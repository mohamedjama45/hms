<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <data>

        <record id="sector_tree" model="ir.ui.view">
            <field name="name">sector.tree</field>
            <field name="model">h.sector</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>


        <record id="sector_form" model="ir.ui.view">
            <field name="name">sector.form</field>
            <field name="model">h.sector</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="sector_action" model="ir.actions.act_window">
            <field name="name">Sector</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">h.sector</field>
            <field name="view_mode">tree,kanban,form</field>
        </record>

         <menuitem
            id="hospital_root"
            name="Hospital"
            sequence="2"
    />



        <menuitem
                id="sector_root"
                name="Sector"
                parent="hospital_root"
                action="sector_action"
                sequence="2"
        />

    </data>

</odoo>